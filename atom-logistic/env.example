# Backend (ECS) - set as environment variables or in ECS task definition
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USERNAME=
# DB_PASSWORD=
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_REGION=us-east-2
# CORS_ORIGIN=https://your-cloudfront-domain.cloudfront.net
# PORT=3000

# Frontend - set at build time for Vite (prefix with VITE_)
# VITE_API_URL=https://your-alb-url.us-east-2.elb.amazonaws.com
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=
