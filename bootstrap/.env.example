# =============================================================================
# Bootstrap: Terraform State Backend (S3 only)
# =============================================================================
# Copy to .env and fill in values:
#   cp .env.example .env
# Then run: source .env && ./create-state-bucket.sh
# Or: export $(grep -v '^#' .env | xargs) && ./create-state-bucket.sh
# =============================================================================

# Project name (used for resource naming; must match terraform.tfvars project_name)
PROJECT_NAME=my-project-test

# Environment: dev, staging, prod
ENVIRONMENT=dev

# AWS region for state bucket
AWS_REGION=us-east-2

# Bucket name is derived: terraform-state-${PROJECT_NAME}-${ENVIRONMENT}-${timestamp}

# DynamoDB: set true only if using -d for team locking (default: S3 + use_lockfile)
CREATE_LOCK_TABLE=false
# TF_LOCK_TABLE=terraform-state-lock

# Use KMS encryption: true | false (recommended true for production)
USE_KMS=false

# Optional: AWS CLI profile (leave empty to use default credentials)
# AWS_PROFILE=default
